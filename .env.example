# Shared
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# TokenOps / Zama
# Optional. The TokenOps SDK resolves the Sepolia factory address automatically.
NEXT_PUBLIC_TOKENOPS_FACTORY_ADDRESS=
# Optional registry deployed from contracts/.
NEXT_PUBLIC_PHASE_REGISTRY_ADDRESS=

# Demo defaults. Replace with ERC-7984 cUSDC on Sepolia.
NEXT_PUBLIC_DEFAULT_CONFIDENTIAL_TOKEN=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_CUSDC_TOKEN_ADDRESS=
NEXT_PUBLIC_CUSDC_FAUCET_ADDRESS=

# Supabase (server-side only - set in Vercel project env, not NEXT_PUBLIC)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional local/demo fallback:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-side claim issuing is intentionally not enabled by default.
# For production, use a backend/HSM wallet with DEFAULT_ADMIN_ROLE on the airdrop clone.
OPERATOR_PRIVATE_KEY=
RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Contracts package
MNEMONIC=test test test test test test test test test test test junk
ETHERSCAN_API_KEY=
