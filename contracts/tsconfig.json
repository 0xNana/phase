{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node", "mocha"],
    "outDir": "dist"
  },
  "include": ["./hardhat.config.ts", "./deploy/**/*.ts", "./test/**/*.ts", "./tasks/**/*.ts"]
}
